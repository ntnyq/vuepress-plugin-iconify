{
  "name": "vuepress-plugin-iconify",
  "type": "module",
  "version": "0.9.0",
  "packageManager": "pnpm@11.8.0",
  "description": "Using icons more easier in VuePress",
  "keywords": [
    "icon",
    "iconify",
    "svg",
    "vuepress",
    "vuepress-plugin"
  ],
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "homepage": "https://vuepress-plugin-iconify.ntnyq.com",
  "repository": "ntnyq/vuepress-plugin-iconify",
  "bugs": {
    "url": "https://github.com/ntnyq/vuepress-plugin-iconify/issues"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/node/index.mjs",
    "./client": "./dist/client/index.mjs",
    "./client/*": "./dist/client/*",
    "./shared": "./dist/shared/index.mjs",
    "./shared/*": "./dist/shared/*"
  },
  "main": "./dist/node/index.mjs",
  "types": "./dist/node/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "deploy": "run-s build docs:build",
    "dev": "tsdown --watch",
    "dev:lib": "tsc -b --watch",
    "docs:build": "pnpm -C docs run build",
    "docs:dev": "pnpm -C docs run dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s lint typecheck test build",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vuepress": "^2.0.0-rc.30"
  },
  "dependencies": {
    "@iconify/utils": "^3.1.3",
    "@iconify/vue": "^5.0.1",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@ntnyq/eslint-config": "^6.1.5",
    "@types/node": "^26.0.0",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.55.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vuepress": "catalog:"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx,vue,md,yml,yaml,json}": "eslint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
